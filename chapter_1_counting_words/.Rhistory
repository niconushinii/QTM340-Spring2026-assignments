filter(word %in% identifiers_for_man) %>%
distinct(sentence_id)
hansard_man <- hansard_1850 %>%
filter(sentence_id %in% man_sentence_ids$sentence_id)
man_context <- hansard_man %>%
unnest_tokens(word, text) %>%
anti_join(stop_words, by = "word") %>%
filter(!str_detect(word, "[:digit:]")) %>%
filter(!word %in% identifiers_for_man) %>%
count(word, sort = TRUE)
